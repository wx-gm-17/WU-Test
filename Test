<!DOCTYPE html>
<html lang="en" translate="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0b141d">
<title>Cannoli Pro v16 (High-Res)</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1"></script>
<script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8/hammer.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1"></script>
<script src="https://cdn.jsdelivr.net/npm/luxon@3.4.4"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-luxon@1.3.1"></script>

<style>
:root { --bg: #060d14; --card: rgba(18, 32, 47, 0.95); --accent: #00d2ff; --border: rgba(255, 255, 255, 0.15); --text: #fff; }
body { margin:0; background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; }
header { background: #0b141d; padding: 20px; border-bottom: 2px solid var(--border); }
.header-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.date-selector { display: flex; gap: 10px; align-items: center; background: #14212d; padding: 10px; border-radius: 12px; border: 1px solid var(--border); width: fit-content; }
input[type="date"] { background: transparent; color: white; border: none; font-family: inherit; font-size: 16px; outline: none; color-scheme: dark; }

.dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; padding: 25px; }
.card { background: var(--card); padding: 40px 20px; border-radius: 28px; text-align: center; border: 2px solid var(--border); cursor: pointer; }
.label { font-size: 16px; text-transform: uppercase; color: #8899a6; font-weight: 900; letter-spacing: 2px; }
.main-val { font-size: 80px; font-weight: 900; margin: 10px 0; line-height: 1; }
.sub-val { font-size: 18px; color: var(--accent); font-weight: 700; }

.btn { background: var(--accent); border: none; padding: 10px 18px; border-radius: 10px; font-weight: 900; cursor: pointer; color: #000; }
.overlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background: var(--bg); z-index: 1000; flex-direction:column; }
.toolbar { display:flex; padding:15px; background: #0b141d; border-bottom: 2px solid var(--border); align-items: center; gap: 10px; }
.chart-box { height: 55vh; background: #000; padding: 10px; touch-action: none; }
.table-wrapper { margin-top: 20px; overflow-x: auto; background: #0b141d; border-radius: 12px; border: 1px solid var(--border); }
table { width: 100%; border-collapse: collapse; font-size: 15px; }
th, td { padding: 12px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.05); }
th { color: var(--accent); font-weight: 900; text-transform: uppercase; }
</style>
</head>
<body>

<header>
  <div class="header-top">
    <div style="font-weight: 900; font-size: 20px;">🐾 CANNOLI PRO v16</div>
    <button class="btn" onclick="openMaster()">MASTER LOG</button>
  </div>
  <div class="date-selector">
    <input type="date" id="targetDate" onchange="loadNewDate()">
  </div>
</header>

<div class="dashboard">
  <div class="card" onclick="openChart('temp')">
    <div class="label">Temperature</div>
    <div id="v-temp" class="main-val">--</div>
    <div id="v-feels" class="sub-val" style="color: #ffaa00;">Apparent: --</div>
    <div id="v-dew" class="sub-val" style="font-size: 15px; opacity: 0.8; margin-top: 8px;">Dew Point: --</div>
  </div>
  
  <div class="card" onclick="openChart('wind')">
    <div class="label">Wind Speed</div>
    <div id="v-wind" class="main-val">--</div>
    <div class="sub-val">MPH</div>
  </div>

  <div class="card" onclick="openChart('wind')">
    <div class="label">Wind Gusts</div>
    <div id="v-gust" class="main-val">--</div>
    <div id="v-maxgust" class="sub-val">DAY MAX: --</div>
  </div>

  <div class="card" onclick="openChart('humidity')">
    <div class="label">Humidity</div>
    <div id="v-hum" class="main-val">--</div>
  </div>
</div>

<div id="overlay-chart" class="overlay">
  <div class="toolbar">
    <h3 id="chart-title" style="flex:1; margin:0;">ANALYSIS</h3>
    <button class="btn" style="background:#333; color:white;" onclick="resetChartZoom()">RESET</button>
    <button class="btn" onclick="closeOverlay('overlay-chart')">✕</button>
  </div>
  <div class="content" style="padding: 10px;">
    <div class="chart-box"><canvas id="main-canvas"></canvas></div>
  </div>
</div>

<div id="overlay-master" class="overlay">
  <div class="toolbar">
    <h3 style="flex:1; margin:0;">MASTER LOG</h3>
    <button class="btn" onclick="closeOverlay('overlay-master')">CLOSE</button>
  </div>
  <div class="content" style="padding: 20px;">
    <div class="table-wrapper">
      <table>
        <thead><tr><th>Time</th><th>Temp</th><th>Dew</th><th>Wind</th><th>Gust</th><th>Humidity</th></tr></thead>
        <tbody id="master-body"></tbody>
      </table>
    </div>
  </div>
</div>

<script>
const wuKey = "0b649979d0b348b1a49979d0b318b138";
const stationId = "KCOARVAD722";
let historyData = [], chartInstance = null;

function getApparent(t, h, w) {
  if (t <= 50 && w > 3) return 35.74 + (0.6215 * t) - (35.75 * Math.pow(w, 0.16)) + (0.4275 * t * Math.pow(w, 0.16));
  if (t >= 80) return -42.379 + 2.04901523*t + 10.14333127*h - 0.22475541*t*h - 0.00683783*t*t - 0.05481717*h*h + 0.00122874*t*t*h + 0.00085282*t*h*h - 0.00000199*t*t*h*h;
  return t;
}

async function fetchData(dateStr = null) {
  const dateParam = dateStr ? dateStr.replace(/-/g, '') : new Date().toISOString().slice(0,10).replace(/-/g, '');
  // Using the 'all' history endpoint to get highest resolution available (minute-level)
  const url = `https://api.weather.com/v2/pws/history/all/1day?stationId=${stationId}&format=json&units=e&date=${dateParam}&apiKey=${wuKey}`;
  
  try {
    const r = await fetch(url);
    const json = await r.json();
    historyData = json.observations || [];
    if(historyData.length > 0) updateUI();
  } catch(e) { console.error("WU Error:", e); }
}

function updateUI() {
  const latest = historyData[historyData.length - 1];
  const t = latest.imperial.tempAvg, h = latest.humidityAvg, w = latest.imperial.windspeedAvg;
  
  document.getElementById('v-temp').innerText = Math.round(t) + "°";
  document.getElementById('v-feels').innerText = "Apparent: " + Math.round(getApparent(t, h, w)) + "°";
  document.getElementById('v-dew').innerText = "Dew Point: " + Math.round(latest.imperial.dewptAvg) + "°";
  document.getElementById('v-wind').innerText = Math.round(w);
  document.getElementById('v-gust').innerText = Math.round(latest.imperial.windgustHigh);
  document.getElementById('v-hum').innerText = h + "%";
  document.getElementById('v-maxgust').innerText = "DAY MAX: " + Math.round(Math.max(...historyData.map(d => d.imperial.windgustHigh))) + " MPH";
}

function openChart(type) {
  document.getElementById('overlay-chart').style.display = 'flex';
  const ctx = document.getElementById('main-canvas');
  if(chartInstance) chartInstance.destroy();

  const labels = historyData.map(d => new Date(d.obsTimeLocal));
  let datasets = [];

  if(type === 'temp') {
    datasets.push({ label: 'TEMP', data: historyData.map(d => d.imperial.tempAvg), borderColor: '#00d2ff', fill: true, backgroundColor: 'rgba(0,210,255,0.05)', pointRadius: 0, tension: 0.2 });
    datasets.push({ label: 'DEW', data: historyData.map(d => d.imperial.dewptAvg), borderColor: '#00ffaa', borderDash: [5,5], pointRadius: 0 });
  } else if(type === 'wind') {
    datasets.push({ label: 'WIND', data: historyData.map(d => d.imperial.windspeedAvg), borderColor: '#00d2ff', pointRadius: 0 });
    datasets.push({ label: 'GUST', data: historyData.map(d => d.imperial.windgustHigh), borderColor: '#ff4d4d', pointRadius: 0 });
  } else if(type === 'humidity') {
    datasets.push({ label: 'HUMIDITY', data: historyData.map(d => d.humidityAvg), borderColor: '#00ffaa', pointRadius: 0 });
  }

  chartInstance = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        zoom: { pan: { enabled: true, mode: 'x' }, zoom: { pinch: { enabled: true }, wheel: { enabled: true }, mode: 'x' } },
        annotation: { annotations: (type === 'temp') ? { line1: { type: 'line', yMin: 32, yMax: 32, borderColor: 'rgba(255, 255, 255, 0.4)', borderWidth: 2, borderDash: [6, 6] } } : {} }
      },
      scales: { x: { type: 'time', time: { unit: 'hour' }, grid: { display: false }, ticks: { color: '#8899a6' } }, y: { ticks: { color: '#8899a6' } } }
    }
  });
}

function openMaster() {
  document.getElementById('overlay-master').style.display = 'flex';
  document.getElementById('master-body').innerHTML = historyData.slice().reverse().map(d => `
    <tr>
      <td>${d.obsTimeLocal.split(' ')[1]}</td>
      <td>${Math.round(d.imperial.tempAvg)}°</td>
      <td>${Math.round(d.imperial.dewptAvg)}°</td>
      <td>${Math.round(d.imperial.windspeedAvg)}</td>
      <td>${Math.round(d.imperial.windgustHigh)}</td>
      <td>${d.humidityAvg}%</td>
    </tr>
  `).join('');
}

function loadNewDate() { fetchData(document.getElementById('targetDate').value); }
function closeOverlay(id) { document.getElementById(id).style.display = 'none'; }
function resetChartZoom() { if(chartInstance) chartInstance.resetZoom(); }

// Set default date to today and initialize
document.getElementById('targetDate').valueAsDate = new Date();
fetchData();
</script>
</body>
</html>
