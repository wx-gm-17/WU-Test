<!DOCTYPE html>
<html lang="en" translate="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Cannoli Pro v18</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1"></script>
<script src="https://cdn.jsdelivr.net/npm/luxon@3.4.4"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-luxon@1.3.1"></script>

<style>
:root { --bg: #060d14; --card: rgba(18, 32, 47, 0.95); --accent: #00d2ff; --border: rgba(255, 255, 255, 0.15); --text: #fff; }
body { margin:0; background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; }
header { background: #0b141d; padding: 20px; border-bottom: 2px solid var(--border); }
.status-msg { font-size: 12px; color: #ff4d4d; padding: 5px 20px; background: rgba(255,0,0,0.1); display: none; }
.dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; padding: 25px; }
.card { background: var(--card); padding: 40px 20px; border-radius: 28px; text-align: center; border: 2px solid var(--border); }
.main-val { font-size: 70px; font-weight: 900; margin: 10px 0; }
.sub-val { font-size: 18px; color: var(--accent); font-weight: 700; }
.btn { background: var(--accent); border: none; padding: 10px 18px; border-radius: 10px; font-weight: 900; }
.overlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background: var(--bg); z-index: 1000; flex-direction:column; }
</style>
</head>
<body>

<header>
  <div style="display:flex; justify-content:space-between; align-items:center;">
    <div style="font-weight:900; font-size:20px;">🐾 CANNOLI PRO v18</div>
    <input type="date" id="targetDate" onchange="loadNewDate()" style="background:#14212d; color:white; border:1px solid var(--border); padding:5px; border-radius:5px;">
  </div>
</header>
<div id="status" class="status-msg"></div>

<div class="dashboard">
  <div class="card"><div style="color:#8899a6; font-weight:900;">TEMP</div><div id="v-temp" class="main-val">--</div><div id="v-dew" class="sub-val">--</div></div>
  <div class="card"><div style="color:#8899a6; font-weight:900;">WIND</div><div id="v-wind" class="main-val">--</div><div id="v-gust" class="sub-val">--</div></div>
  <div class="card"><div style="color:#8899a6; font-weight:900;">SOLAR</div><div id="v-sol" class="main-val">--</div><div id="v-uv" class="sub-val">--</div></div>
  <div class="card"><div style="color:#8899a6; font-weight:900;">HUMIDITY</div><div id="v-hum" class="main-val">--</div></div>
  <div class="card"><div style="color:#8899a6; font-weight:900;">RAIN</div><div id="v-rain" class="main-val">--</div></div>
</div>

<script>
const wuKey = "0b649979d0b348b1a49979d0b318b138";
const stationId = "KCOARVAD722";
let historyData = [];

async function fetchData(dateStr = null) {
  const status = document.getElementById('status');
  status.style.display = 'none';
  
  const dateParam = dateStr ? dateStr.replace(/-/g, '') : new Date().toISOString().slice(0,10).replace(/-/g, '');
  
  // USING A PROXY TO BYPASS CORS
  const targetUrl = `https://api.weather.com/v2/pws/history/all/1day?stationId=${stationId}&format=json&units=e&date=${dateParam}&apiKey=${wuKey}`;
  const proxyUrl = `https://api.allorigins.win/get?url=${encodeURIComponent(targetUrl)}`;

  try {
    const response = await fetch(proxyUrl);
    const wrapper = await response.json();
    const json = JSON.parse(wrapper.contents);
    
    historyData = json.observations || [];
    if(historyData.length > 0) {
        updateUI();
    } else {
        status.innerText = "No data found for this date.";
        status.style.display = 'block';
    }
  } catch(e) { 
    status.innerText = "Error: Connection blocked or Key invalid.";
    status.style.display = 'block';
    console.error(e); 
  }
}

function updateUI() {
  const latest = historyData[historyData.length - 1];
  const imp = latest.imperial;
  document.getElementById('v-temp').innerText = Math.round(imp.tempAvg) + "°";
  document.getElementById('v-dew').innerText = "Dew: " + Math.round(imp.dewptAvg) + "°";
  document.getElementById('v-wind').innerText = Math.round(imp.windspeedAvg);
  document.getElementById('v-gust').innerText = "Gust: " + Math.round(imp.windgustHigh) + " MPH";
  document.getElementById('v-hum').innerText = latest.humidityAvg + "%";
  document.getElementById('v-sol').innerText = Math.round(latest.solarRadiationHigh || 0);
  document.getElementById('v-uv').innerText = "UV: " + (latest.uvHigh || 0);
  document.getElementById('v-rain').innerText = imp.precipTotal.toFixed(2) + '"';
}

function loadNewDate() { fetchData(document.getElementById('targetDate').value); }
document.getElementById('targetDate').valueAsDate = new Date();
fetchData();
</script>
</body>
</html>
